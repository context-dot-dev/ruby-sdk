module ContextDev
  module Resources
    class Brand
      def retrieve: (
        domain: String,
        ?force_language: ContextDev::Models::BrandRetrieveParams::force_language,
        ?max_speed: bool,
        ?timeout_ms: Integer,
        ?request_options: ContextDev::request_opts
      ) -> ContextDev::Models::BrandRetrieveResponse

      def identify_from_transaction: (
        transaction_info: String,
        ?city: String,
        ?country_gl: ContextDev::Models::BrandIdentifyFromTransactionParams::country_gl,
        ?force_language: ContextDev::Models::BrandIdentifyFromTransactionParams::force_language,
        ?high_confidence_only: bool,
        ?max_speed: bool,
        ?mcc: String,
        ?phone: Float,
        ?timeout_ms: Integer,
        ?request_options: ContextDev::request_opts
      ) -> ContextDev::Models::BrandIdentifyFromTransactionResponse

      def retrieve_by_email: (
        email: String,
        ?force_language: ContextDev::Models::BrandRetrieveByEmailParams::force_language,
        ?max_speed: bool,
        ?timeout_ms: Integer,
        ?request_options: ContextDev::request_opts
      ) -> ContextDev::Models::BrandRetrieveByEmailResponse

      def retrieve_by_isin: (
        isin: String,
        ?force_language: ContextDev::Models::BrandRetrieveByIsinParams::force_language,
        ?max_speed: bool,
