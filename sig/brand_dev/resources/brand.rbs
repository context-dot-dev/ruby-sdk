        ?request_options: BrandDev::request_opts
      ) -> BrandDev::Models::BrandStyleguideResponse

      def web_scrape_html: (
        url: String,
        ?request_options: BrandDev::request_opts
      ) -> BrandDev::Models::BrandWebScrapeHTMLResponse

